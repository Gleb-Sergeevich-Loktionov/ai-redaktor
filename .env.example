# Скопируй в .env и заполни. .env НЕ коммитить.

# Токен бота из BotFather
TELEGRAM_BOT_TOKEN=

# Ключ Anthropic API
ANTHROPIC_API_KEY=

# Модель (баланс цена/качество для редактуры)
MODEL=claude-sonnet-4-6

# Максимум символов на один запрос (защита от длинных текстов и стоимости)
MAX_CHARS=20000

# Максимальный размер входного файла, МБ
MAX_FILE_MB=10
